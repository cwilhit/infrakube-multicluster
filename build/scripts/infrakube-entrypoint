#!/bin/sh -e

# This is documented here:
# https://docs.openshift.com/container-platform/3.11/creating_images/guidelines.html#openshift-specific-guidelines
#
# Keep this wrapper so the controller still works when the platform runs the
# container with an arbitrary UID and `whoami` expects an /etc/passwd entry.

if ! whoami &>/dev/null; then
  if [ -w /etc/passwd ]; then
    echo "${USER_NAME:-infrakube}:x:$(id -u):$(id -g):${USER_NAME:-infrakube} user:${HOME}:/sbin/nologin" >> /etc/passwd
  fi
fi

exec ${OPERATOR} $@
